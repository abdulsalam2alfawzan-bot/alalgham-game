rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // MVP rules: enough for private testing with anonymous auth.
    // Production should move activation redemption and score authority to a trusted server.
    match /activationCodes/{code} {
      allow get: if signedIn();
      allow list: if false;
      allow create: if false;
      allow update: if signedIn()
        && resource.data.status == "unused"
        && request.resource.data.status in ["reserved", "used"]
        && request.resource.data.reservedByUid == request.auth.uid;
      allow delete: if false;
    }

    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow get: if true;
      allow list: if false;
      allow create: if signedIn()
        && request.resource.data.organizerUid == request.auth.uid;
      allow update: if signedIn()
        && resource.data.organizerUid == request.auth.uid;
      allow delete: if false;

      match /players/{playerId} {
        allow read: if true;
        allow create: if signedIn()
          && request.resource.data.uid == request.auth.uid;
        allow update: if signedIn()
          && (
            resource.data.uid == request.auth.uid ||
            get(/databases/$(database)/documents/rooms/$(roomId)).data.organizerUid == request.auth.uid
          );
        allow delete: if false;
      }

      match /teams/{teamId} {
        allow read: if true;
        allow create, update: if signedIn()
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.organizerUid == request.auth.uid;
        allow delete: if false;
      }

      match /boards/{boardId} {
        allow read: if true;
        allow create, update: if signedIn();
        allow delete: if false;
      }

      match /turns/{turnId} {
        allow read: if true;
        allow create, update: if signedIn();
        allow delete: if false;
      }

      match /events/{eventId} {
        allow read: if true;
        allow create: if signedIn();
        allow update, delete: if false;
      }

      match /objections/{objectionId} {
        allow read: if true;
        allow create: if signedIn();
        allow update: if signedIn()
          && get(/databases/$(database)/documents/rooms/$(roomId)).data.organizerUid == request.auth.uid;
        allow delete: if false;
      }
    }
  }
}
