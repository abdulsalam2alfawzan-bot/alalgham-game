rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function room(roomId) {
      return get(/databases/$(database)/documents/rooms/$(roomId));
    }

    function keepsRoomCodesUnchanged(roomId) {
      return request.resource.data.ownerCode == resource.data.ownerCode
        && request.resource.data.playerCode == resource.data.playerCode;
    }

    // MVP rules for anonymous-auth testing.
    // Production note:
    // A fully static client cannot securely enforce owner-code possession,
    // expiry, score changes, or judge permissions by itself. Production should
    // harden these checks with stricter Firestore rules, custom claims, or
    // trusted server-side validation if the room codes carry monetary value.

    match /questions/{questionId} {
      allow read: if true;
      allow write: if false;
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if false;
    }

    match /rooms/{roomId} {
      allow get: if true;
      allow list: if false;

      // Rooms are pre-created outside the public app. Public users must not
      // create rooms or change owner/player codes from the client.
      allow create: if false;

      // MVP keeps client updates available for the active room while preventing
      // accidental code changes. UI permissions gate supervisor-only actions.
      allow update: if signedIn() && keepsRoomCodesUnchanged(roomId);
      allow delete: if false;

      match /players/{playerId} {
        allow read: if true;

        // Player joins are room-scoped and must start with role="player".
        allow create: if signedIn()
          && request.resource.data.roomId == roomId
          && request.resource.data.role == "player"
          && request.resource.data.status == "active";

        // Production should restrict captain/team/status changes to a verified
        // room owner. MVP relies on UI handlers to block player escalation.
        allow update: if signedIn()
          && request.resource.data.roomId == roomId
          && !("ownerCode" in request.resource.data)
          && !("playerCode" in request.resource.data);
        allow delete: if false;
      }

      match /teams/{teamId} {
        allow read: if true;

        // Players cannot assign captains, modify scores, edit team names, or
        // change board readiness in the UI. Production must enforce owner-only
        // writes with stronger authorization.
        allow create, update: if signedIn();
        allow delete: if false;
      }

      match /boards/{teamId} {
        allow read: if true;

        // MVP allows signed-in captains to submit boards client-side. Production
        // should validate that the writer is the team's captain and enforce the
        // exact board distribution.
        allow create, update: if signedIn();
        allow delete: if false;
      }

      match /turns/{turnId} {
        allow read: if true;

        // Production should prevent players from judging answers or changing turn
        // state. MVP keeps writes signed-in while UI/handlers enforce roles.
        allow create, update: if signedIn();
        allow delete: if false;
      }

      match /events/{eventId} {
        allow read: if true;

        // Event text must be sanitized by the client. Production should validate
        // event types and prevent forged supervisor events.
        allow create: if signedIn();
        allow update, delete: if false;
      }

      match /objections/{objectionId} {
        allow read: if true;
        allow create: if signedIn();
        allow update: if signedIn();
        allow delete: if false;
      }

      match /questionsUsed/{questionId} {
        allow read: if true;
        allow create, update: if signedIn();
        allow delete: if false;
      }
    }
  }
}
